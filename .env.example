# Netlify Functions + Resend
# Server-side only — do NOT use VITE_ prefix for these keys.

# Where to set in production:
# Netlify Dashboard → Site configuration → Environment variables
# Scope: "All" or "Functions"
# After adding/changing vars, trigger a new deploy.

RESEND_API_KEY=re_xxxxxxxxxx
ENQUIRY_FROM_EMAIL=Ananta One <noreply@anantaone.in>
ENQUIRY_TO_EMAIL=experts@anantaone.in

# Local development with functions:
# 1. Copy this file to `.env`
# 2. Run: npx netlify dev
# (npm run dev alone will NOT load function env vars)

# Optional client override:
# VITE_ENQUIRY_API_URL=/api/enquiry
